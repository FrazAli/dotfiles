// Personal keybindings.
//
// A binding declared here overrides the same key combination from an earlier
// include while leaving all unrelated CachyOS bindings intact.

binds {
    // Match the Hyprland Noctalia launcher shortcut.
    Super+Space hotkey-overlay-title="Application Launcher" {
        spawn "qs" "-c" "noctalia-shell" "ipc" "call" "launcher" "toggle";
    }
    Super+Period hotkey-overlay-title="Emoji Picker" {
        spawn "qs" "-c" "noctalia-shell" "ipc" "call" "launcher" "emoji";
    }


    // macOS-style Firefox shortcuts with their normal compositor fallbacks.
    Mod+T hotkey-overlay-title="New Firefox Tab / Open Ghostty" {
        spawn-sh "$HOME/.config/niri/custom/scripts/firefox-shortcut t terminal";
    }
    Mod+W hotkey-overlay-title="Close Firefox Tab / Close Window" {
        spawn-sh "$HOME/.config/niri/custom/scripts/firefox-shortcut w close-window";
    }
    Mod+F hotkey-overlay-title="Find in Firefox / Toggle Fullscreen" {
        spawn-sh "$HOME/.config/niri/custom/scripts/firefox-shortcut f fullscreen";
    }
    Mod+B hotkey-overlay-title="Firefox Bookmarks / Pass Super+B" {
        spawn-sh "$HOME/.config/niri/custom/scripts/firefox-shortcut b pass-super";
    }
    Mod+L hotkey-overlay-title="Firefox Address Bar / Lock Screen" {
        spawn-sh "$HOME/.config/niri/custom/scripts/firefox-shortcut l lock-screen";
    }
    Mod+P hotkey-overlay-title="Print in Firefox / Pick Color" {
        spawn-sh "$HOME/.config/niri/custom/scripts/firefox-shortcut p color-picker";
    }

    // Switch to fullscreen
    Mod+Return hotkey-overlay-title="Toggle Fullscreen"      { fullscreen-window; }

    // Vim-style navigation continues into the adjacent workspace when there
    // is no next window in the focused column.
    Mod+J { focus-window-or-workspace-down; }
    Mod+K { focus-window-or-workspace-up; }

    // Rectangle-style window manipulation.
    Ctrl+Alt+Return { fullscreen-window; }
    Ctrl+Alt+H      { move-column-left; }
    Ctrl+Alt+J      { move-window-down; }
    Ctrl+Alt+K      { move-window-up; }
    Ctrl+Alt+L      { move-column-right; }
    Ctrl+Alt+Space  { toggle-window-floating; }
    Ctrl+Alt+Minus  hotkey-overlay-title="Decrease Column Width" { set-column-width "-10%"; }
    Ctrl+Alt+Equal  hotkey-overlay-title="Increase Column Width" { set-column-width "+10%"; }

    // macOS-style lock-screen shortcut.
    Ctrl+Super+Q hotkey-overlay-title="Lock Screen" {
        spawn "qs" "-c" "noctalia-shell" "ipc" "call" "lockScreen" "lock";
    }

    // Noctalia panels and bar.
    Ctrl+Alt+V hotkey-overlay-title="Clipboard History" {
        spawn "qs" "-c" "noctalia-shell" "ipc" "call" "launcher" "clipboard";
    }
    Super+N hotkey-overlay-title="Notification History" {
        spawn "qs" "-c" "noctalia-shell" "ipc" "call" "notifications" "toggleHistory";
    }
    Super+S hotkey-overlay-title="Toggle Bar" {
        spawn "qs" "-c" "noctalia-shell" "ipc" "call" "bar" "toggle";
    }

    // macOS-style selected-region screenshot.
    Super+Shift+4 hotkey-overlay-title="Screenshot Region" { screenshot; }
}
