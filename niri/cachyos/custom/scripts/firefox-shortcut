#!/usr/bin/env bash

# On-demand dispatcher for macOS-style Super shortcuts.
#
# Niri starts this script with:
#
#   firefox-shortcut <key> <fallback>
#
# When Firefox is focused, the requested key is sent as Ctrl+<key>, giving us
# Firefox's native new-tab, close-tab, find, bookmarks, address-bar, print, and
# reload shortcuts. In every other application, the named compositor fallback
# runs.
#
# Fallbacks:
#
#   terminal           Open Ghostty.
#   close-window       Close the focused Niri window.
#   fullscreen         Toggle true fullscreen.
#   pass-super         Forward Super+<key> to the focused application.
#   focus-column-right Focus the column to the right.
#   color-picker       Pick a screen pixel and copy its hex color.
#
# pass-super temporarily enables Niri's keyboard-shortcut inhibition. Without
# it, the forwarded virtual Super key would trigger this dispatcher recursively.

set -euo pipefail

key="${1:?missing shortcut key}"
fallback="${2:?missing fallback action}"

app_id="$(niri msg -j focused-window 2>/dev/null | jq -r '.app_id // ""')"
app_id="${app_id,,}"

case "$app_id" in
    firefox|firefox-*|org.mozilla.firefox)
        # wtype uses a virtual keyboard, so Firefox receives a normal Ctrl
        # accelerator rather than the Super binding consumed by Niri.
        wtype -M ctrl -k "$key" -m ctrl
        ;;
    *)
        case "$fallback" in
            terminal)
                ghostty
                ;;
            close-window)
                niri msg action close-window
                ;;
            fullscreen)
                niri msg action fullscreen-window
                ;;
            pass-super)
                niri msg action toggle-keyboard-shortcuts-inhibit
                if ! wtype -M logo -k "$key" -m logo; then
                    niri msg action toggle-keyboard-shortcuts-inhibit
                    exit 1
                fi
                niri msg action toggle-keyboard-shortcuts-inhibit
                ;;
            focus-column-right)
                niri msg action focus-column-right
                ;;
            color-picker)
                geometry="$(slurp -p -f '%x,%y 1x1')" || exit 0
                color="$(
                    grim -g "$geometry" -t ppm - |
                        magick ppm:- -depth 8 -format '#%[hex:p{0,0}]' info:
                )"
                printf '%s' "$color" | wl-copy
                notify-send "Color copied" "$color"
                ;;
            *)
                printf 'Unknown fallback action: %s\n' "$fallback" >&2
                exit 2
                ;;
        esac
        ;;
esac
