// Edit with `hyprshell config edit`.
(
    version: 4,
    windows: (
        scale: 8.5,
        items_per_row: 5,
        switch: (
            modifier: "alt",
            key: "Tab",
            filter_by: [],
            switch_workspaces: false,
            exclude_workspaces: "special:.*",
            kill_key: 'q',
        ),
    ),
)
