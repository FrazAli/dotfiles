#!/usr/bin/env bash

set -euo pipefail

config_file="${XDG_CONFIG_HOME:-$HOME/.config}/noctalia/settings.json"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
temporary_file="$(mktemp)"
trap 'rm -f -- "$temporary_file"' EXIT

jq -f "$script_dir/bar-layout.jq" "$config_file" > "$temporary_file"
jq --exit-status '.' "$temporary_file" >/dev/null
install -m 0644 "$temporary_file" "$config_file"

echo "Applied the Noctalia v4 bar layout to $config_file"
